{
  "name": "purroxy-web",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:worker": "wrangler pages dev dist --d1 purroxy-db --r2 purroxy-packages --kv PURROXY_KV",
    "build": "vite build",
    "preview": "wrangler pages dev dist",
    "deploy": "npm run build && wrangler pages deploy dist --project-name purroxy-web --commit-dirty=true && sleep 5 && npm run test:deploy",
    "test:deploy": "bash scripts/test-deploy.sh https://purroxy.com",
    "test:deploy:preview": "bash scripts/test-deploy.sh",
    "db:migrate": "wrangler d1 migrations apply purroxy-db --remote",
    "db:migrate:local": "wrangler d1 migrations apply purroxy-db --local",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "hono": "^4.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.2",
    "stripe": "^21.0.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250327.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/vite": "^4.2.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.5.2",
    "daisyui": "^5.5.19",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "^6.3.5",
    "vitest": "^4.1.2",
    "wrangler": "^4.80.0"
  }
}
